  dialogueName: Ducky
  npc: {fileID: 11400000, guid: bb63f896063009947aef9d41b24cde21, type: 2}
  lines:
  - id: line_1
    speakerName: NPC
    text: "Hey, hey! Haven\u2019t seen a face like yours around here before!\r"
    nextNodeID: line_2
    setFlag: 0
    flagToSet: 
    flagValue: 0
    useCondition: 0
    requiredFlag: 
    trueNodeID: 
    falseNodeID: 
  - id: line_2
    speakerName: NPC
    text: "So, what do you have here? What are you doing on this island?\r"
    nextNodeID: line_3
    setFlag: 0
    flagToSet: 
    flagValue: 0
    useCondition: 0
    requiredFlag: 
    trueNodeID: 
    falseNodeID: 
  - id: line_3
    speakerName: NPC
    text: "You look pretty lost\u2026 don\u2019t worry, I\u2019ll give you a few
      tips. Free of charge!\r"
    nextNodeID: line_4
    setFlag: 0
    flagToSet: 
    flagValue: 0
    useCondition: 0
    requiredFlag: 
    trueNodeID: 
    falseNodeID: 
  - id: line_4
    speakerName: NPC
    text: "This island is divided into four regions, and each one is packed with
      countless kinds of fish\u2014more than you can imagine.\r"
    nextNodeID: line_5
    setFlag: 0
    flagToSet: 
    flagValue: 0
    useCondition: 0
    requiredFlag: 
    trueNodeID: 
    falseNodeID: 
  - id: line_5
    speakerName: NPC
    text: "This part of the island is home to tropical fish and creatures of all
      shapes and colors.\r"
    nextNodeID: line_6
    setFlag: 0
    flagToSet: 
    flagValue: 0
    useCondition: 0
    requiredFlag: 
    trueNodeID: 
    falseNodeID: 
  - id: line_6
    speakerName: Player
    text: 'Huh? And how are you supposed to discover all of them?

'
    nextNodeID: line_7
    setFlag: 0
    flagToSet: 
    flagValue: 0
    useCondition: 0
    requiredFlag: 
    trueNodeID: 
    falseNodeID: 
  - id: line_7
    speakerName: NPC
    text: "That\u2019s where your skill as a fisher comes in. I only know one fisher
      in this island\u2019s history who managed to catch so many species from every
      region\u2026 "
    nextNodeID: line_8
    setFlag: 0
    flagToSet: 
    flagValue: 0
    useCondition: 0
    requiredFlag: 
    trueNodeID: 
    falseNodeID: 
  - id: line_8
    speakerName: NPC
    text: "You know\u2026 you kinda remind me of him.\r"
    nextNodeID: line_9
    setFlag: 0
    flagToSet: 
    flagValue: 0
    useCondition: 0
    requiredFlag: 
    trueNodeID: 
    falseNodeID: 
  - id: line_9
    speakerName: NPC
    text: "Anyway, I wish you a safe journey\u2014and don\u2019t forget to keep your
      fishing rod sharp."
    nextNodeID: 
    setFlag: 0
    flagToSet: 
    flagValue: 0
    useCondition: 0
    requiredFlag: 
